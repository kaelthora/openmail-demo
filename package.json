{
  "name": "openmail-demo",
  "version": "0.1.0",
  "private": true,
  "description": "OpenMail — AI-native mail demo",
  "author": "OpenMail",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "npx prisma db push --accept-data-loss && next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "electron": "electron .",
    "desktop:dev": "concurrently -k \"npm:dev\" \"npm:electron:wait\"",
    "electron:wait": "wait-on http://localhost:3000 && electron .",
    "desktop:build": "npm run build",
    "desktop:prod": "concurrently -k \"npm:start\" \"npm:desktop:prod:electron\"",
    "desktop:prod:electron": "wait-on http://localhost:3000 && electron .",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "imapflow": "^1.2.18",
    "lamejs": "^1.2.1",
    "lucide-react": "^1.8.0",
    "mailparser": "^3.9.6",
    "matter-js": "^0.20.0",
    "next": "16.1.6",
    "node-lame": "^2.0.2",
    "nodemailer": "^8.0.4",
    "openai": "^6.25.0",
    "prisma": "^6.19.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/matter-js": "^0.20.2",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.openmail.app",
    "productName": "OpenMail",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "package.json",
      "next.config.ts",
      "postcss.config.mjs",
      "app/**/*",
      "lib/**/*",
      "public/**/*",
      ".next/**/*",
      "!**/.next/cache/**",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "artifactName": "OpenMail-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
